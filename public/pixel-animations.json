{
  "_readme": {
    "description": "Animations 2D pixel art par boss. Chaque entrée utilise l'ID exact du boss dans library.json.",
    "spriteSheet": "Chemin relatif à /public/ vers votre PNG spritesheet.",
    "frameWidth": "Largeur d'une frame en pixels (toutes les frames ont la même taille).",
    "frameHeight": "Hauteur d'une frame en pixels.",
    "scale": "Facteur d'agrandissement canvas (recommandé : 2 à 4 pour pixel art net).",
    "offsetY": "Décalage vertical en pixels CSS pour centrer/ajuster verticalement dans le viewer.",
    "animations": {
      "_info": "Clés possibles : idle, attack, hit, death, rage. Ajoutez librement vos propres états.",
      "row": "Numéro de ligne (0-based) dans la spritesheet.",
      "frames": "Nombre de frames sur cette ligne.",
      "fps": "Vitesse de lecture en frames par seconde.",
      "loop": "true = boucle continue, false = arrêt sur la dernière frame."
    },
    "spritesheet_format": "Horizontal : chaque ligne = 1 animation, chaque colonne = 1 frame. Toutes les cellules font frameWidth x frameHeight px. Export depuis Aseprite : Sprite Sheet > Horizontal Strip."
  },

